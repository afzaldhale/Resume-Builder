# Application runtime
NODE_ENV=production
HOST=127.0.0.1
PORT=5000
APP_ORIGIN=http://localhost:5000
FRONTEND_URL=http://localhost:5000

# Security
JWT_SECRET=replace-with-a-long-random-secret

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=resume_builder
DB_USER=root
DB_PASSWORD=
DB_CONNECTION_LIMIT=10
DB_CONNECT_RETRIES=10
DB_CONNECT_DELAY_MS=5000
DB_CONNECT_TIMEOUT_MS=10000

# Browser access control
# Add your frontend origins here when you want to lock CORS down explicitly.
# Example: http://localhost:8080,http://127.0.0.1:8080,http://192.168.1.7:8080
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:8080,http://127.0.0.1:8080

# PDF generation
PDF_TIMEOUT=60000
PDF_DEBUG_SCREENSHOT=false
PUPPETEER_EXECUTABLE_PATH=
